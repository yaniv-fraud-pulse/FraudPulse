{
  "version": 2,
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/features",
      "destination": "/solutions",
      "permanent": true
    },
    {
      "source": "/features/",
      "destination": "/solutions/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fraud-pulse.com" }],
      "destination": "https://www.fraud-pulse.com/:path*",
      "permanent": true
    }
  ]
}
